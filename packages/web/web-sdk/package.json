{
  "name": "@contentful/optimization-web",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contentful/optimization.git",
    "directory": "packages/web/web-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger.d.mts",
        "default": "./dist/logger.mjs"
      },
      "require": {
        "types": "./dist/logger.d.cts",
        "default": "./dist/logger.cjs"
      }
    },
    "./constants": {
      "import": {
        "types": "./dist/constants.d.mts",
        "default": "./dist/constants.mjs"
      },
      "require": {
        "types": "./dist/constants.d.cts",
        "default": "./dist/constants.cjs"
      }
    },
    "./bridge-support": {
      "import": {
        "types": "./dist/bridge-support.d.mts",
        "default": "./dist/bridge-support.mjs"
      },
      "require": {
        "types": "./dist/bridge-support.d.cts",
        "default": "./dist/bridge-support.cjs"
      }
    },
    "./presentation": {
      "import": {
        "types": "./dist/presentation.d.mts",
        "default": "./dist/presentation.mjs"
      },
      "require": {
        "types": "./dist/presentation.d.cts",
        "default": "./dist/presentation.cjs"
      }
    },
    "./tracking-attributes": {
      "import": {
        "types": "./dist/tracking-attributes.d.mts",
        "default": "./dist/tracking-attributes.mjs"
      },
      "require": {
        "types": "./dist/tracking-attributes.d.cts",
        "default": "./dist/tracking-attributes.cjs"
      }
    },
    "./web-components": {
      "import": {
        "types": "./dist/web-components.d.mts",
        "default": "./dist/web-components.mjs"
      },
      "require": {
        "types": "./dist/web-components.d.cts",
        "default": "./dist/web-components.cjs"
      }
    },
    "./core-sdk": {
      "import": {
        "types": "./dist/core-sdk.d.mts",
        "default": "./dist/core-sdk.mjs"
      },
      "require": {
        "types": "./dist/core-sdk.d.cts",
        "default": "./dist/core-sdk.cjs"
      }
    },
    "./runtime": {
      "import": {
        "types": "./dist/runtime.d.mts",
        "default": "./dist/runtime.mjs"
      },
      "require": {
        "types": "./dist/runtime.d.cts",
        "default": "./dist/runtime.cjs"
      }
    },
    "./api-client": {
      "import": {
        "types": "./dist/api-client.d.mts",
        "default": "./dist/api-client.mjs"
      },
      "require": {
        "types": "./dist/api-client.d.cts",
        "default": "./dist/api-client.cjs"
      }
    },
    "./api-schemas": {
      "import": {
        "types": "./dist/api-schemas.d.mts",
        "default": "./dist/api-schemas.mjs"
      },
      "require": {
        "types": "./dist/api-schemas.d.cts",
        "default": "./dist/api-schemas.cjs"
      }
    }
  },
  "files": [
    "dist/**/*",
    "THIRD_PARTY_NOTICES.txt"
  ],
  "buildTools": {
    "bundleSize": {
      "gzipBudgets": {
        "contentful-optimization-web.umd.js": 34500,
        "index.cjs": 12500,
        "index.mjs": 12500,
        "bridge-support.cjs": 1200,
        "bridge-support.mjs": 1200,
        "contentful-optimization-web-components.umd.js": 39000,
        "presentation.cjs": 3200,
        "presentation.mjs": 3200,
        "tracking-attributes.cjs": 1200,
        "tracking-attributes.mjs": 1200,
        "web-components.cjs": 16000,
        "web-components.mjs": 17500
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:dist",
    "build:ci": "pnpm build:dist",
    "build:dist": "rslib build && build-tools emit-dual-dts ./dist",
    "build:rsdoctor": "RSDOCTOR=true rslib build && build-tools emit-dual-dts ./dist",
    "clean": "rimraf ./.rsdoctor ./.rslib ./dist ./coverage .tsbuildinfo ./node_modules/.cache/rspack",
    "dev": "rsbuild dev --host 0.0.0.0 -c dev/rsbuild.config.ts",
    "size:check": "pnpm build:dist && build-tools bundle-size",
    "size:report": "build-tools bundle-size --report-only",
    "test:unit": "rstest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contentful/optimization-core": "workspace:*",
    "contentful": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@rsdoctor/cli": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "build-tools": "workspace:*",
    "happy-dom": "catalog:",
    "rimraf": "catalog:",
    "tslib": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
