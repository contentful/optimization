{
  "name": "@contentful/optimization-react-web",
  "version": "0.0.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contentful/optimization.git",
    "directory": "packages/web/frameworks/react-web-sdk"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./logger": {
      "import": {
        "types": "./dist/logger.d.mts",
        "default": "./dist/logger.mjs"
      },
      "require": {
        "types": "./dist/logger.d.cts",
        "default": "./dist/logger.cjs"
      }
    },
    "./web-sdk": {
      "import": {
        "types": "./dist/web-sdk.d.mts",
        "default": "./dist/web-sdk.mjs"
      },
      "require": {
        "types": "./dist/web-sdk.d.cts",
        "default": "./dist/web-sdk.cjs"
      }
    },
    "./core-sdk": {
      "import": {
        "types": "./dist/core-sdk.d.mts",
        "default": "./dist/core-sdk.mjs"
      },
      "require": {
        "types": "./dist/core-sdk.d.cts",
        "default": "./dist/core-sdk.cjs"
      }
    },
    "./api-client": {
      "import": {
        "types": "./dist/api-client.d.mts",
        "default": "./dist/api-client.mjs"
      },
      "require": {
        "types": "./dist/api-client.d.cts",
        "default": "./dist/api-client.cjs"
      }
    },
    "./api-schemas": {
      "import": {
        "types": "./dist/api-schemas.d.mts",
        "default": "./dist/api-schemas.mjs"
      },
      "require": {
        "types": "./dist/api-schemas.d.cts",
        "default": "./dist/api-schemas.cjs"
      }
    },
    "./router/next-pages": {
      "import": {
        "types": "./dist/router/next-pages.d.mts",
        "default": "./dist/router/next-pages.mjs"
      },
      "require": {
        "types": "./dist/router/next-pages.d.cts",
        "default": "./dist/router/next-pages.cjs"
      }
    },
    "./router/next-app": {
      "import": {
        "types": "./dist/router/next-app.d.mts",
        "default": "./dist/router/next-app.mjs"
      },
      "require": {
        "types": "./dist/router/next-app.d.cts",
        "default": "./dist/router/next-app.cjs"
      }
    },
    "./router/react-router": {
      "import": {
        "types": "./dist/router/react-router.d.mts",
        "default": "./dist/router/react-router.mjs"
      },
      "require": {
        "types": "./dist/router/react-router.d.cts",
        "default": "./dist/router/react-router.cjs"
      }
    },
    "./router/tanstack-router": {
      "import": {
        "types": "./dist/router/tanstack-router.d.mts",
        "default": "./dist/router/tanstack-router.mjs"
      },
      "require": {
        "types": "./dist/router/tanstack-router.d.cts",
        "default": "./dist/router/tanstack-router.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*"
  ],
  "buildTools": {
    "bundleSize": {
      "gzipBudgets": {
        "index.cjs": 3300,
        "index.mjs": 2200
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:dist",
    "build:ci": "pnpm build:dist",
    "build:dist": "rslib build && build-tools emit-dual-dts ./dist && build-tools emit-dual-dts ./dist/router",
    "build:rsdoctor": "RSDOCTOR=true rslib build && build-tools emit-dual-dts ./dist && build-tools emit-dual-dts ./dist/router",
    "clean": "rimraf ./.rsdoctor ./.rslib ./dist ./coverage .tsbuildinfo",
    "dev": "rsbuild dev --host 0.0.0.0 -c dev/rsbuild.config.ts",
    "size:check": "pnpm build:dist && build-tools bundle-size",
    "size:report": "build-tools bundle-size --report-only",
    "test:unit": "rstest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contentful/optimization-web": "workspace:*",
    "react": "19.2.3",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@rsbuild/core": "catalog:",
    "@rsbuild/plugin-react": "^1.4.2",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@tanstack/react-router": "^1.132.33",
    "build-tools": "workspace:*",
    "contentful": "catalog:",
    "happy-dom": "catalog:",
    "next": "^16.2.1",
    "react-router-dom": "^7.9.5",
    "rimraf": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "@tanstack/react-router": ">=1.0.0",
    "next": ">=13.0.0",
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1",
    "react-router-dom": ">=6.4.0"
  },
  "peerDependenciesMeta": {
    "@tanstack/react-router": {
      "optional": true
    },
    "next": {
      "optional": true
    },
    "react-router-dom": {
      "optional": true
    }
  }
}
