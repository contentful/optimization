{
  "name": "@contentful/optimization-nextjs",
  "description": "Next.js adapter for Contentful Optimization",
  "version": "1.0.1",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/contentful/optimization.git",
    "directory": "packages/web/frameworks/nextjs-sdk"
  },
  "type": "module",
  "exports": {
    "./app-router": {
      "react-server": {
        "types": "./dist/app-router-server.d.mts",
        "default": "./dist/app-router-server.mjs"
      },
      "import": {
        "types": "./dist/app-router.d.mts",
        "default": "./dist/app-router.mjs"
      },
      "require": {
        "types": "./dist/app-router.d.cts",
        "default": "./dist/app-router.cjs"
      }
    },
    "./client": {
      "import": {
        "types": "./dist/client.d.mts",
        "default": "./dist/client.mjs"
      },
      "require": {
        "types": "./dist/client.d.cts",
        "default": "./dist/client.cjs"
      }
    },
    "./api-schemas": {
      "import": {
        "types": "./dist/api-schemas.d.mts",
        "default": "./dist/api-schemas.mjs"
      },
      "require": {
        "types": "./dist/api-schemas.d.cts",
        "default": "./dist/api-schemas.cjs"
      }
    },
    "./server": {
      "import": {
        "types": "./dist/server.d.mts",
        "default": "./dist/server.mjs"
      },
      "require": {
        "types": "./dist/server.d.cts",
        "default": "./dist/server.cjs"
      }
    },
    "./esr": {
      "import": {
        "types": "./dist/esr.d.mts",
        "default": "./dist/esr.mjs"
      },
      "require": {
        "types": "./dist/esr.d.cts",
        "default": "./dist/esr.cjs"
      }
    },
    "./pages-router": {
      "import": {
        "types": "./dist/pages-router.d.mts",
        "default": "./dist/pages-router.mjs"
      },
      "require": {
        "types": "./dist/pages-router.d.cts",
        "default": "./dist/pages-router.cjs"
      }
    },
    "./pages-router/server": {
      "import": {
        "types": "./dist/pages-router/server.d.mts",
        "default": "./dist/pages-router/server.mjs"
      },
      "require": {
        "types": "./dist/pages-router/server.d.cts",
        "default": "./dist/pages-router/server.cjs"
      }
    },
    "./request-handler": {
      "import": {
        "types": "./dist/request-handler.d.mts",
        "default": "./dist/request-handler.mjs"
      },
      "require": {
        "types": "./dist/request-handler.d.cts",
        "default": "./dist/request-handler.cjs"
      }
    },
    "./tracking-attributes": {
      "import": {
        "types": "./dist/tracking-attributes.d.mts",
        "default": "./dist/tracking-attributes.mjs"
      },
      "require": {
        "types": "./dist/tracking-attributes.d.cts",
        "default": "./dist/tracking-attributes.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist/**/*",
    "THIRD_PARTY_NOTICES.txt"
  ],
  "buildTools": {
    "bundleSize": {
      "gzipBudgets": {
        "app-router.cjs": 1200,
        "app-router.mjs": 1200,
        "app-router-server.cjs": 3800,
        "app-router-server.mjs": 4250,
        "client.cjs": 1200,
        "client.mjs": 1200,
        "esr.cjs": 4200,
        "esr.mjs": 4200,
        "pages-router.cjs": 1200,
        "pages-router.mjs": 1200,
        "pages-router/server.cjs": 3600,
        "pages-router/server.mjs": 4000,
        "server.cjs": 4500,
        "server.mjs": 4500,
        "request-handler.cjs": 2500,
        "request-handler.mjs": 2800,
        "tracking-attributes.cjs": 1200,
        "tracking-attributes.mjs": 1200
      }
    }
  },
  "scripts": {
    "build": "pnpm clean && pnpm build:dist",
    "build:ci": "pnpm build:dist",
    "build:dist": "rslib build && build-tools check-client-boundary-exports ./src ./dist && build-tools emit-dual-dts ./dist && build-tools emit-dual-dts ./dist/pages-router",
    "build:rsdoctor": "RSDOCTOR=true rslib build && build-tools emit-dual-dts ./dist && build-tools emit-dual-dts ./dist/pages-router",
    "clean": "rimraf ./.rsdoctor ./.rslib ./dist ./coverage .tsbuildinfo ./node_modules/.cache/rspack",
    "size:check": "pnpm build:dist && build-tools bundle-size",
    "size:report": "build-tools bundle-size --report-only",
    "test:unit": "rstest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contentful/optimization-node": "workspace:*",
    "@contentful/optimization-react-web": "workspace:*",
    "@contentful/optimization-web": "workspace:*"
  },
  "devDependencies": {
    "@rsbuild/plugin-react": "^1.4.2",
    "@rsdoctor/cli": "catalog:",
    "@rslib/core": "catalog:",
    "@rstest/core": "catalog:",
    "@rstest/coverage-istanbul": "catalog:",
    "@types/node": "catalog:",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "build-tools": "workspace:*",
    "contentful": "catalog:",
    "happy-dom": "catalog:",
    "next": "^16.2.6",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "rimraf": "catalog:",
    "tslib": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "next": ">=13.0.0",
    "react": ">=18.3.1",
    "react-dom": ">=18.3.1"
  }
}
