{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "baseUrl": "./src",
    "emitDeclarationOnly": true,
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": ["./src/**/*", "./src/**/*.json"],
  "exclude": ["./src/**/*.test.*"],
  "extends": "../../../../tsconfig.base.json",
  "references": [
    { "path": "../../../node/node-sdk/tsconfig.build.json" },
    { "path": "../../web-sdk/tsconfig.build.json" },
    { "path": "../react-web-sdk/tsconfig.build.json" }
  ]
}
