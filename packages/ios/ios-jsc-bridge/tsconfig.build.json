{
  "compilerOptions": {
    "composite": true,
    "incremental": true,
    "noEmit": false,
    "baseUrl": "./src",
    "emitDeclarationOnly": true,
    "lib": ["ESNext", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "./src",
    "tsBuildInfoFile": "./.tsbuildinfo"
  },
  "include": ["./src/**/*"],
  "exclude": ["./src/**/*.test.*"],
  "extends": "../../../tsconfig.base.json",
  "references": [
    { "path": "../../universal/core-sdk/tsconfig.build.json" },
    { "path": "../../universal/preview-sdk/tsconfig.build.json" }
  ]
}
