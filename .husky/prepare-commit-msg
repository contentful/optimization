#!/bin/bash

set -e

# Only skip when Git already populated the message from a known source.
case "${2-}" in
  message | template | merge | squash | commit)
    exit 0
    ;;
esac

[ -r /dev/tty ] || exit 0

if [ -s "$1" ] && grep -Eq '^[[:space:]]*[^#[:space:]]' "$1"; then
  exit 0
fi

exec </dev/tty
pnpm exec tsx scripts/prepare-commit-message.ts "$1"
