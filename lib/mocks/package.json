{
  "private": true,
  "name": "mocks",
  "version": "0.0.0",
  "description": "Testing Support Library & Server",
  "license": "MIT",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./loggerMock": "./src/loggerMock.ts"
  },
  "files": [
    "dist/**/*"
  ],
  "scripts": {
    "clean": "rimraf ./.rsdoctor ./.rslib ./dist ./coverage .tsbuildinfo ./.cache",
    "config:ctfl:list": "contentful config list",
    "fetch:ctfl": "pnpm fetch:ctfl:space && pnpm fetch:ctfl:entries",
    "fetch:ctfl:entries": "tsx ./scripts/fetchEntries.ts",
    "fetch:ctfl:space": "contentful space export --config .contentfulrc.json",
    "generate:ctfl:types": "tsx ./scripts/generateTypeDefinition.ts && tsx ./scripts/copyGeneratedTypeDefinition.ts",
    "serve": "tsx ./src/server.ts",
    "test:unit": "rstest run --coverage --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "upload:ctfl:space": "read -p 'This will overwrite your space data! Do you really want to do this? (y/N)' yn && [ \"$yn\" = 'y' ] && pnpm upload:ctfl:space:confirmed",
    "upload:ctfl:space:confirmed": "contentful space import --config .contentfulrc.json"
  },
  "dependencies": {
    "@contentful/optimization-api-schemas": "workspace:*",
    "@mswjs/http-middleware": "0.10.3",
    "msw": "catalog:",
    "tslib": "catalog:"
  },
  "devDependencies": {
    "@rstest/core": "catalog:",
    "@types/express": "catalog:",
    "@types/fs-extra": "^11.0.4",
    "@types/node": "catalog:",
    "contentful": "catalog:",
    "contentful-cli": "^3.10.4",
    "dotenv": "catalog:",
    "es-toolkit": "catalog:",
    "fs-extra": "^11.3.3",
    "p-retry": "catalog:",
    "rimraf": "catalog:",
    "tsx": "catalog:",
    "typescript": "catalog:"
  }
}
