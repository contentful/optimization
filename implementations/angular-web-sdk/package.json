{
  "name": "@implementation/angular-web-sdk",
  "private": true,
  "version": "0.0.0",
  "description": "Reference implementation for Angular Web applications using @contentful/optimization-web",
  "license": "MIT",
  "scripts": {
    "dev": "ng serve",
    "build": "ng build",
    "clean": "rimraf ./dist",
    "serve:mocks": "pm2 start --name angular-web-sdk-mocks \"pnpm --dir ../../lib/mocks serve\"",
    "serve:mocks:stop": "pm2 stop angular-web-sdk-mocks && pm2 delete angular-web-sdk-mocks",
    "test:unit": "echo \"No unit tests necessary\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular/build": "^22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/node": "^24.0.13",
    "pm2": "^6.0.14",
    "rimraf": "^6.1.3",
    "typescript": "~6.0.3"
  }
}
