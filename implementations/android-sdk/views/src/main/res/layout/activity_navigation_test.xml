<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:padding="8dp">

    <!-- Close button is always visible (matches the Compose `Button { Close }` in the NavigationHome
         destination — the Views impl exposes it on every screen so tests can return to MainActivity
         from any nested view without needing to navigate back through the stack). -->
    <Button
        android:id="@+id/close_navigation_test_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Close" />

    <!-- Home state -->
    <LinearLayout
        android:id="@+id/navigation_home"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <Button
            android:id="@+id/go_to_view_one_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Go to View One" />

        <TextView
            android:id="@+id/home_screen_event_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>

    <!-- View One state -->
    <LinearLayout
        android:id="@+id/navigation_view_one"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/view_one_last_screen_event"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/view_one_screen_event_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <Button
            android:id="@+id/go_to_view_two_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Go to View Two" />
    </LinearLayout>

    <!-- View Two state -->
    <LinearLayout
        android:id="@+id/navigation_view_two"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <TextView
            android:id="@+id/view_two_last_screen_event"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />

        <TextView
            android:id="@+id/view_two_screen_event_log"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" />
    </LinearLayout>
</LinearLayout>
