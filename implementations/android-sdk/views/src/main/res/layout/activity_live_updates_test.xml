<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    android:fillViewport="true"
    android:id="@+id/live_updates_scroll_view">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Updates Test Controls"
            android:textStyle="bold" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <Button
                android:id="@+id/close_live_updates_test_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Close" />

            <Button
                android:id="@+id/live_updates_identify_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identify" />

            <Button
                android:id="@+id/live_updates_reset_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Reset"
                android:visibility="gone" />

            <Button
                android:id="@+id/toggle_global_live_updates_button"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Global: OFF" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingTop="8dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Identified: " />

            <TextView
                android:id="@+id/identified_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="No" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Global Live Updates: " />

            <TextView
                android:id="@+id/global_live_updates_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="OFF" />
        </LinearLayout>

        <Button
            android:id="@+id/simulate_preview_panel_button"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="Simulate Preview Panel" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Preview Panel: " />

            <TextView
                android:id="@+id/preview_panel_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Closed" />
        </LinearLayout>

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Default Behavior (inherits global setting)" />

        <com.contentful.optimization.views.OptimizedEntryView
            android:id="@+id/default_slot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Live Updates Enabled (liveUpdates=true)" />

        <com.contentful.optimization.views.OptimizedEntryView
            android:id="@+id/live_slot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <Space
            android:layout_width="match_parent"
            android:layout_height="16dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Locked (liveUpdates=false)" />

        <com.contentful.optimization.views.OptimizedEntryView
            android:id="@+id/locked_slot"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />
    </LinearLayout>
</ScrollView>
