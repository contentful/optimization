{
  "private": true,
  "name": "@implementation/node-ssr-web-vanilla",
  "description": "Reference implementation for NodeJS Web projects",
  "license": "MIT",
  "main": "dist/app.js",
  "types": "dist/app.d.ts",
  "scripts": {
    "build": "pnpm clean && pnpm build:sdk",
    "build:sdk": "mkdir -p ./public/dist && cp -r ./node_modules/@contentful/optimization-web/dist/. ./public/dist",
    "clean": "rimraf ./dist ./public/dist ./coverage ./playwright-report ./test-results .tsbuildinfo",
    "serve": "pnpm serve:mocks && pnpm serve:app",
    "serve:app": "pnpm build && pm2 start --name esr-app \"tsx --env-file=.env ./src/app.ts\"",
    "serve:app:stop": "pm2 stop esr-app && pm2 delete esr-app",
    "serve:mocks": "pm2 start --name esr-mocks \"pnpm --dir ../../lib/mocks serve\"",
    "serve:mocks:stop": "pm2 stop esr-mocks && pm2 delete esr-mocks",
    "serve:stop": "pnpm serve:app:stop && pnpm serve:mocks:stop",
    "test:e2e": "pnpm serve && playwright test; E2E_RESULT=$?; pnpm serve:stop; exit $E2E_RESULT",
    "test:e2e:codegen": "playwright codegen",
    "test:e2e:report": "playwright show-report",
    "test:e2e:ui": "playwright test --ui",
    "test:unit": "rstest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@contentful/optimization-node": "0.0.0",
    "@contentful/optimization-web": "0.0.0",
    "cookie-parser": "^1.4.7",
    "ejs": "^3.1.10",
    "express": "^5.2.1",
    "express-rate-limit": "^8.2.1",
    "qs": "^6.14.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@contentful/optimization-core": "0.0.0",
    "@playwright/test": "^1.57.0",
    "@types/express": "^5.0.6",
    "@types/node": "^24.0.13",
    "@types/qs": "^6.14.0",
    "@types/supertest": "^6.0.3",
    "@rstest/core": "^0.8.5",
    "@rstest/coverage-istanbul": "^0.2.1",
    "@types/cookie-parser": "1.4.7",
    "dotenv": "^17.3.1",
    "pm2": "^6.0.14",
    "rimraf": "^6.1.3",
    "supertest": "^7.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "pnpm": {
    "overrides": {
      "@contentful/optimization-api-client": "file:../../pkgs/contentful-optimization-api-client-0.0.0.tgz",
      "@contentful/optimization-api-schemas": "file:../../pkgs/contentful-optimization-api-schemas-0.0.0.tgz",
      "@contentful/optimization-core": "file:../../pkgs/contentful-optimization-core-0.0.0.tgz",
      "@contentful/optimization-node": "file:../../pkgs/contentful-optimization-node-0.0.0.tgz",
      "@contentful/optimization-web": "file:../../pkgs/contentful-optimization-web-0.0.0.tgz"
    }
  }
}
