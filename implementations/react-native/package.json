{
  "name": "@implementation/react-native",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier . --check",
    "format:fix": "prettier . --write",
    "start": "react-native start",
    "start:clean": "kill-port 8081 && react-native start --reset-cache",
    "prestart": "kill-port 8081 || true",
    "serve:mocks": "pnpm --dir ../../lib/mocks serve",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:unit": "echo 'Unit tests skipped - this is a reference implementation app. E2E tests are run separately via Detox.'",
    "test:e2e:ios:build": "detox build --configuration ios.sim.debug",
    "test:e2e:ios:run": "detox test --configuration ios.sim.debug",
    "test:e2e:ios": "pnpm run test:e2e:ios:build && pnpm run test:e2e:ios:run",
    "test:e2e:android:build": "detox build --configuration android.emu.debug",
    "test:e2e:android:build:release": "detox build --configuration android.emu.release",
    "test:e2e:android:run": "detox test --configuration android.emu.debug --loglevel fatal --record-logs none --take-screenshots none --record-videos none",
    "test:e2e:android:run:release": "detox test --configuration android.emu.release --loglevel fatal --record-logs none --take-screenshots none --record-videos none",
    "test:e2e:android": "pnpm run test:e2e:android:build && pnpm run test:e2e:android:run",
    "test:e2e:android:full": "./scripts/run-e2e-android.sh"
  },
  "dependencies": {
    "@contentful/optimization-react-native": "0.0.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-clipboard/clipboard": "1.16.3",
    "@react-native-community/netinfo": "12.0.1",
    "@react-navigation/native": "7.1.28",
    "@react-navigation/native-stack": "7.13.0",
    "contentful": "11.10.3",
    "core-js": "3.48.0",
    "react": "19.2.3",
    "react-native": "0.84.0",
    "react-native-safe-area-context": "5.6.2",
    "react-native-screens": "4.23.0",
    "hermes-compiler": "250829098.0.7"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-proposal-decorators": "7.29.0",
    "@babel/plugin-transform-class-properties": "7.28.6",
    "@babel/plugin-transform-class-static-block": "7.28.6",
    "@babel/plugin-transform-export-namespace-from": "7.27.1",
    "@babel/plugin-transform-private-methods": "7.28.6",
    "@babel/runtime": "7.28.6",
    "@jest/globals": "29.7.0",
    "@react-native-community/cli": "20.1.1",
    "@react-native-community/cli-platform-android": "20.1.1",
    "@react-native-community/cli-platform-ios": "20.1.1",
    "@react-native/babel-preset": "0.84.0",
    "@react-native/codegen": "0.84.0",
    "@react-native/gradle-plugin": "0.84.0",
    "@react-native/metro-config": "0.84.0",
    "@react-native/typescript-config": "0.84.0",
    "@testing-library/react-native": "13.3.3",
    "@types/react": "19.2.14",
    "@types/react-test-renderer": "19.1.0",
    "babel-jest": "29.7.0",
    "detox": "20.47.0",
    "dotenv": "17.3.1",
    "jest": "29.7.0",
    "jest-circus": "30.2.0",
    "kill-port": "2.0.1",
    "react-native-dotenv": "3.4.11",
    "react-test-renderer": "19.2.3",
    "typescript": "5.9.3"
  },
  "pnpm": {
    "overrides": {
      "@contentful/optimization-api-client": "file:../../pkgs/contentful-optimization-api-client-0.0.0.tgz",
      "@contentful/optimization-api-schemas": "file:../../pkgs/contentful-optimization-api-schemas-0.0.0.tgz",
      "@contentful/optimization-core": "file:../../pkgs/contentful-optimization-core-0.0.0.tgz",
      "@contentful/optimization-react-native": "file:../../pkgs/contentful-optimization-react-native-0.0.0.tgz"
    }
  }
}
